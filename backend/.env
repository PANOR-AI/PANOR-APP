# ═══════════════════════════════════════════════════════
#  PANOR — Environment Configuration
#  Copy this file to .env and fill in your own values.
# ═══════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────
PROJECT_NAME=PANOR
API_V1_STR=/api

# ── Security ──────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080    # 7 days
REFRESH_TOKEN_EXPIRE_MINUTES=43200   # 30 days

# PostgreSQL (Docker / Production / Local strict enforcement):
DATABASE_URL=postgresql+asyncpg://postgres:postgrespassword@localhost:5433/panor


# ── Redis / Celery ────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# Docker:
# REDIS_URL=redis://redis:6379/0

# ── AI Layer (Gemini) ──────────────────────────────────
# Path to your GCP service-account JSON key OR your raw Gemini API key
GEMINI_API_KEY=AIzaSyC32Jlp82giwCzp9ELXRtNZoZj1Tp6Lnzc

